"""
Environment configuration template.

Copy this file to .env and update values for your environment.
"""

# API Configuration
API_TITLE=EBM-SVM Demo API
API_DESCRIPTION=API for EBM-SVM integration and machine learning tasks
API_VERSION=1.0.0
DEBUG=True

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://localhost:8000"]

# File Upload Configuration
UPLOAD_DIR=utils/upload_temp
DOWNLOAD_DIR=utils/download
MAX_UPLOAD_SIZE=52428800
ALLOWED_FILE_EXTENSIONS=[".csv", ".xlsx", ".txt"]

# EBM Model Configuration
EBM_EPOCHS=200
EBM_LR=0.0005
EBM_HIDDEN_DIM=256
EBM_EMBEDDING_DIM=64
EBM_NOISE_SCALE=0.5

# SVM Configuration
SVM_KERNEL=rbf
SVM_C=1.0

# Data Processing Configuration
TEST_SIZE=0.2
RANDOM_SEED=42
